{
  "expo": {
    "name": "MilkRound",
    "slug": "milkround",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "milkround",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.milkround.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAF5"
      },
      "package": "com.milkround.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MilkRound to use the camera to scan supplier QR codes."
        }
      ]
    ]
  }
}
